# ============================================================
# 社交媒体矩阵智能运营系统 - 环境变量模板
# ============================================================
# 复制此文件为 .env 并填入实际值

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=sm_admin
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=social_media
DATABASE_URL=postgresql://sm_admin:your_postgres_password@postgres:5432/social_media

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://:your_redis_password@redis:6379

# ============================================================
# 服务器
# ============================================================
NODE_ENV=development
TS_API_PORT=3001
TZ=Asia/Shanghai

# ============================================================
# 阿里云 OSS
# ============================================================
OSS_REGION=cn-beijing
OSS_BUCKET=naite-mes
OSS_ENDPOINT=img.naite.cc
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# ============================================================
# Python Worker
# ============================================================
PYTHON_WORKER_URL=http://python-worker:8000

# ============================================================
# LiteLLM Proxy
# ============================================================
LITELLM_URL=http://litellm:4000
LITELLM_API_KEY=your_litellm_master_key
LITELLM_MASTER_KEY=your_litellm_master_key
UI_USERNAME=admin
UI_PASSWORD=your_litellm_master_key
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
ZHIPU_API_KEY=your_zhipu_api_key

# ============================================================
# 指纹浏览器
# ============================================================
ROXY_BROWSER_URL=http://localhost:54345
BIT_BROWSER_URL=http://localhost:54346

# ============================================================
# TS Webhook 回调地址
# ============================================================
TS_WEBHOOK_URL=http://ts-api-gateway:3001/api/v1/webhook/python-callback
