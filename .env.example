# ============================================================
# 社交媒体矩阵智能运营系统 - 环境变量模板
# ============================================================
# 复制此文件为 .env 并填入实际值

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=social_media
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@postgres:5432/social_media

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@redis:6379

# ============================================================
# 服务器
# ============================================================
NODE_ENV=development
TS_API_PORT=3001
TZ=Asia/Shanghai

# ============================================================
# 阿里云 OSS
# ============================================================
OSS_REGION=cn-beijing
OSS_BUCKET=your_oss_bucket
OSS_ENDPOINT=your_oss_endpoint
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# ============================================================
# Python Worker
# ============================================================
PYTHON_WORKER_URL=http://python-worker:8000

# ============================================================
# LiteLLM Proxy
# ============================================================
LITELLM_URL=http://litellm:4000
LITELLM_API_KEY=your_litellm_api_key
LITELLM_MASTER_KEY=your_litellm_master_key
UI_USERNAME=admin
UI_PASSWORD=your_ui_password
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
ZHIPU_API_KEY=your_zhipu_api_key

# ============================================================
# 指纹浏览器
# ============================================================
ROXY_BROWSER_URL=http://localhost:54345
ROXY_BROWSER_KEY=your_roxy_browser_key
BIT_BROWSER_URL=http://localhost:54346

# ============================================================
# 企业微信智能机器人
# ============================================================
WECOM_BOT_ID=your_wecom_bot_id
WECOM_BOT_SECRET=your_wecom_bot_secret

# ============================================================
# TS Webhook 回调地址
# ============================================================
TS_WEBHOOK_URL=http://ts-api-gateway:3001/api/v1/webhook/python-callback

# ============================================================
# 反检测双路径开关（每平台独立，默认 legacy）
# 抖音沿用 ANTI_DETECTION_MODE（docker-compose.yml 默认 v2）
# ============================================================
ANTI_DETECTION_MODE_TENCENT=legacy    # legacy|v2 — 腾讯平台
ANTI_DETECTION_MODE_KUAISHOU=legacy   # legacy|v2 — 快手平台
ANTI_DETECTION_MODE_XIAOHONGSHU=legacy # legacy|v2 — 小红书平台

# ============================================================
# API Gateway 安全密钥
# ============================================================
API_GATEWAY_KEY=your_api_gateway_key
