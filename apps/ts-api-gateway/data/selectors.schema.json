{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://social-media.local/schemas/selectors.schema.json",
  "title": "SelectorConfig",
  "description": "Dynamic DOM selector registry for multi-platform publishers. Persisted by apps/ts-api-gateway/lib/selectorStore.ts and consumed by SelectorReader.",
  "type": "object",
  "required": ["version", "updatedAt", "platforms"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver, e.g. \"1.3.0\". Bump on structural changes (added/removed keys, schema changes)."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last write (UTC, ends with Z)."
    },
    "source": {
      "type": "string",
      "description": "Free-form description of the source pipeline (e.g. \"scripts/extract_selectors.py + apply_overrides.py\")."
    },
    "platforms": {
      "type": "object",
      "description": "Map of platform name to its selector tree.",
      "additionalProperties": { "$ref": "#/$defs/platformSelectors" }
    }
  },
  "$defs": {
    "platformSelectors": {
      "type": "object",
      "required": ["menus", "buttons", "regions", "textboxes"],
      "additionalProperties": false,
      "properties": {
        "menus":     { "type": "object", "additionalProperties": { "$ref": "#/$defs/selectorEntry" } },
        "buttons":   { "type": "object", "additionalProperties": { "$ref": "#/$defs/selectorEntry" } },
        "regions":   { "type": "object", "additionalProperties": { "$ref": "#/$defs/selectorEntry" } },
        "textboxes": { "type": "object", "additionalProperties": { "$ref": "#/$defs/selectorEntry" } },
        "flowRules": { "type": "object", "description": "Publish flow control rules" },
        "urlMonitors": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/urlMonitorEntry" },
          "description": "URL monitoring entries for API interception (v2.4+)"
        }
      }
    },
    "selectorEntry": {
      "type": "object",
      "required": ["purposes", "primary", "fallbacks", "selectorType"],
      "additionalProperties": false,
      "properties": {
        "purposes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["publish", "monitor"] },
          "uniqueItems": true,
          "description": "Workflow stages this selector participates in."
        },
        "primary": {
          "type": "string",
          "minLength": 1,
          "description": "Highest-priority selector. Use getByRole/getByText when possible; fall back to css / xpath only when needed."
        },
        "fallbacks": {
          "type": "array",
          "description": "Ordered list of fallbacks. Index 0 is first attempted after primary fails.",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "selectorType": {
          "type": "string",
          "enum": ["css", "role", "text", "placeholder", "label"],
          "description": "Strategy classification. Must match one of the 9-layer ordered strategies."
        },
        "description": {
          "type": "string",
          "description": "Human-readable purpose/location hint."
        }
      }
    },
    "responseExtraction": {
      "type": "object",
      "required": ["itemsPath", "idField"],
      "additionalProperties": false,
      "properties": {
        "itemsPath": { "type": "string", "description": "JSON path to the data list (e.g. data.list)" },
        "idField": { "type": "string", "description": "Unique ID field path (e.g. exportId)" },
        "fieldMap": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Alias to JSON path mapping" }
      }
    },
    "paginationRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hasMorePath": { "type": "string" },
        "hasMoreValue": {},
        "hasMoreFalseValue": {},
        "cursorPath": { "type": "string" },
        "cursorParamName": { "type": "string" }
      }
    },
    "urlMonitorEntry": {
      "type": "object",
      "required": ["urlPatterns", "method", "extraction"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "urlPatterns": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "extraction": { "$ref": "#/$defs/responseExtraction" },
        "pagination": { "$ref": "#/$defs/paginationRule" },
        "flowPhase": { "type": "string", "description": "Associated business flow phase (e.g. monitor:scan)" },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "expectedPageUrls": { "type": "array", "items": { "type": "string" } },
            "requiredItemFields": { "type": "array", "items": { "type": "string" } },
            "minItems": { "type": "number" },
            "requiredUrlParams": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
