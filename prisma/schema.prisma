// Prisma Schema - 社交媒体矩阵智能运营系统
// PostgreSQL 15+ | Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 一、核心业务表（来自 my_folder TS 项目）
// ============================================================

model User {
  id                   Int      @id @default(autoincrement())
  fingerprintWindowId  String   @map("fingerprint_window_id")
  wechatUserid         String   @map("wechat_userid")
  platform             String   @default("douyin")
  status               String   @default("init") // init | active | blocked | cooldown
  consecutiveNoUpdate  Int      @default(0) @map("consecutive_no_update")
  cooldownUntil        BigInt   @default(0) @map("cooldown_until")
  monitoringEnabled    Boolean  @default(true) @map("monitoring_enabled")
  platformAuthorId     String?  @map("platform_author_id")    // 抖音uid / 快手userId
  platformAuthorName   String?  @map("platform_author_name")  // 作者昵称
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  videos    Video[]
  @@unique([fingerprintWindowId, platform], name: "idx_users_window_platform")
  @@map("users")
}

model Video {
  id           String   @id
  userId       Int      @map("user_id")
  description  String   @default("")
  createTime   BigInt   @map("create_time")
  commentCount Int      @default(0) @map("comment_count")
  metrics      String   @default("{}") // JSON
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([userId], name: "idx_videos_user_id")
  @@index([userId, createTime(sort: Desc)], name: "idx_videos_user_id_create_time")
  @@map("videos")
}

model Comment {
  id           Int      @id @default(autoincrement())
  videoId      String   @map("video_id")
  cid          String   @unique
  text         String   @default("")
  userNickname String   @default("") @map("user_nickname")
  userUid      String   @default("") @map("user_uid")
  diggCount    Int      @default(0) @map("digg_count")
  createTime   BigInt   @map("create_time")
  replyId      String   @default("0") @map("reply_id")
  isNew        Int      @default(1) @map("is_new")
  rootId       String?  @map("root_id")
  parentId     String?  @map("parent_id")
  level        Int      @default(1) @map("level")
  replyToName  String?  @map("reply_to_name")
  isAuthor     Boolean  @default(false) @map("is_author")
  createdAt    DateTime @default(now()) @map("created_at")

  // AI 客服建议字段
  suggestedReply      String?    @map("suggested_reply") @db.Text
  suggestionStatus    String     @default("none") @map("suggestion_status") @db.VarChar(16)
  suggestionModel     String?    @map("suggestion_model") @db.VarChar(64)
  suggestionLatencyMs Int?       @map("suggestion_latency_ms")
  suggestionAt        DateTime?  @map("suggestion_at")
  replyStatus         String     @default("none") @map("reply_status") @db.VarChar(16)
  repliedAt           DateTime?  @map("replied_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId], name: "idx_comments_video_id")
  @@index([cid], name: "idx_comments_cid")
  @@index([videoId, rootId], name: "idx_comments_video_root")
  @@index([suggestionStatus], name: "idx_comments_suggestion_status")
  @@map("comments")
}

model VideoRootCommentCount {
  id         String   @id @default(uuid())
  videoId    String   @map("video_id")
  cid        String
  replyCount Int      @default(0) @map("reply_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([videoId, cid])
  @@map("video_root_comment_counts")
}

// ============================================================
// 二、排期与运行状态表
// ============================================================

model ScheduleRule {
  id           Int      @id @default(autoincrement())
  name         String   @default("")
  ruleType     String   @default("weekday") @map("rule_type") // weekday | date | daily | all_day
  enabled      Boolean  @default(false)
  specificDate String?  @map("specific_date") // YYYY-MM-DD for 'date' type
  daysOfWeek   String   @default("0,6") @map("days_of_week") // comma-separated: 0=Sun,6=Sat
  startTime    String   @default("02:00") @map("start_time") // HH:MM
  endTime      String   @default("08:30") @map("end_time")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("schedule_rules")
}

model OperationLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String   @default("{}") // JSON
  userId    String   @default("") @map("user_id")
  userName  String   @default("") @map("user_name")
  result    String   @default("success") // success | failure
  level     String   @default("info") // info | warn | error
  createdAt DateTime @default(now()) @map("created_at")

  @@map("operation_logs")
}

model SystemStatus {
  id                 Int      @id @default(1)
  status             String   @default("running") // running | paused | error
  currentInterval    Int      @default(180000) @map("current_interval") // ms
  consecutiveChecks  Int      @default(0) @map("consecutive_checks")
  lastCheckTime      BigInt   @default(0) @map("last_check_time")
  totalChecks        Int      @default(0) @map("total_checks")
  isDebugMode        Boolean  @default(false) @map("is_debug_mode")
  enableWarmup       Boolean  @default(false) @map("enable_warmup")
  nextCheckAt        BigInt   @default(0) @map("next_check_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("system_status")
}

// ============================================================
// 三、爬取与平台配置表
// ============================================================

model CrawlSetting {
  id        Int      @id @default(autoincrement())
  platform  String   @unique
  mode      String   @default("deep") // deep | light
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("crawl_settings")
}

model PlatformConfig {
  id          Int      @id @default(autoincrement())
  platform    String
  configKey   String   @map("config_key")
  configValue String   @default("") @map("config_value")
  description String   @default("")
  version     Int      @default(1)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([platform, configKey], name: "idx_platform_config_key")
  @@map("platform_configs")
}

model PlatformConfigAudit {
  id         Int      @id @default(autoincrement())
  platform   String
  configKey  String   @map("config_key")
  oldValue   String   @default("") @map("old_value")
  newValue   String   @map("new_value")
  version    Int
  action     String   @default("update") // update | create | delete
  operator   String   @default("system")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("platform_config_audit")
}

model PageStateCache {
  id                  Int      @id @default(autoincrement())
  platform            String   @unique
  lastRefreshAt       BigInt   @default(0) @map("last_refresh_at")
  lastPageHash        String   @default("") @map("last_page_hash")
  lastDataFingerprint String   @default("") @map("last_data_fingerprint")
  refreshCount        Int      @default(0) @map("refresh_count")
  consecutiveFailures Int      @default(0) @map("consecutive_failures")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("page_state_cache")
}

// ============================================================
// 四、Python 端业务表（来自 n8n-backup 项目）
// ============================================================

model TaskRecord {
  id        Int      @id @default(autoincrement())
  taskId    String   @unique @map("task_id") @db.VarChar(64)
  taskType  String   @map("task_type") @db.VarChar(32)
  status    String   @default("pending") @db.VarChar(16) // pending | running | completed | failed
  params    String?  @db.Text
  result    String?  @db.Text
  error     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_records")
}

model Blogger {
  id        Int      @id @default(autoincrement())
  platform  String   @db.VarChar(32)
  userId    String   @map("user_id") @db.VarChar(128)
  userName  String   @map("user_name") @db.VarChar(128)
  style     String   @default("") @db.VarChar(64)
  followers String   @default("") @db.VarChar(32)
  likes     String   @default("") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([platform], name: "idx_bloggers_platform")
  @@map("bloggers")
}

model BGM {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  filename  String   @unique @db.VarChar(255)
  style     String?  @db.VarChar(50)
  duration  Float?
  ossUrl    String   @map("oss_url") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bgm")
}

model VideoCommentRecord {
  id              Int       @id @default(autoincrement())
  platform        String    @db.VarChar(20) // douyin | xiaohongshu | bilibili | kuaishou
  videoId         String    @map("video_id") @db.VarChar(64)
  commentId       String    @map("comment_id") @db.VarChar(64)
  userId          String?   @map("user_id") @db.VarChar(64)
  nickname        String?   @db.VarChar(128)
  content         String?   @db.Text
  likeCount       Int       @default(0) @map("like_count")
  createTime      BigInt?   @map("create_time")
  createTimestamp DateTime? @map("create_timestamp")

  @@map("video_comments")
}

model MonitorStatus {
  id              Int       @id @default(autoincrement())
  platform        String    @db.VarChar(20)
  accountId       String    @map("account_id") @db.VarChar(64)
  lastCheckTime   DateTime? @map("last_check_time")
  lastVideoCount  Int?      @map("last_video_count")
  lastCommentCount Int?     @map("last_comment_count")
  status          String    @default("running") @db.VarChar(20)

  @@map("monitor_status")
}

model VideoCommentCount {
  id             Int      @id @default(autoincrement())
  platform       String   @db.VarChar(20)
  videoId        String   @map("video_id") @db.VarChar(64)
  commentCount   Int      @default(0) @map("comment_count")
  videoTitle     String?  @map("video_title") @db.VarChar(200)
  lastUpdateTime DateTime @default(now()) @map("last_update_time")

  @@unique([platform, videoId], name: "uq_platform_video")
  @@map("video_comment_counts")
}

// ============================================================
// 五、新增表：动态选择器注册表
// ============================================================

model CustomSelector {
  id          Int      @id @default(autoincrement())
  platform    String   @db.VarChar(32)
  selectorKey String   @map("selector_key") @db.VarChar(128)
  selectorValue String  @map("selector_value") @db.Text // JSON: { css_selector?, xpath?, id_selector?, text_selector? }
  description String   @default("") @db.VarChar(255)
  version     Int      @default(1)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([platform, selectorKey], name: "idx_selector_platform_key")
  @@map("custom_selectors")
}

// ============================================================
// 六、用户与窗口管理表
// ============================================================

/// 操作员（企业微信用户）——系统的管理单位
model Operator {
  id            Int      @id @default(autoincrement())
  wechatUserId  String   @unique @map("wechat_user_id") @db.VarChar(64) // 企业微信用户ID
  displayName   String   @map("display_name") @db.VarChar(64)
  phone         String?  @db.VarChar(20)
  role          String   @default("operator") @db.VarChar(20) // admin | operator
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  windows       BrowserWindow[]
  platforms     OperatorPlatform[]

  @@map("operators")
}

/// 指纹浏览器窗口——通过 BitBrowser / RoxyBrowser API 同步
model BrowserWindow {
  id              Int      @id @default(autoincrement())
  externalId      String   @map("external_id") @db.VarChar(128) // 浏览器API返回的窗口ID
  browserVendor   String   @map("browser_vendor") @db.VarChar(20) // bitbrowser | roxybrowser
  windowName      String   @map("window_name") @default("") @db.VarChar(255)
  workspaceId     String?  @map("workspace_id") @db.VarChar(64) // RoxyBrowser 需要
  boundOperatorId Int?     @map("bound_operator_id") // 绑定的操作员ID
  status          String   @default("available") @db.VarChar(20) // available | bound | error
  rawConfig       String?  @map("raw_config") @db.Text // JSON: 原始窗口配置
  syncedAt        DateTime @default(now()) @map("synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  operator Operator? @relation(fields: [boundOperatorId], references: [id], onDelete: SetNull)

  @@unique([externalId, browserVendor], name: "idx_window_external_vendor")
  @@map("browser_windows")
}

/// 操作员-平台绑定关系——记录每个用户管理哪些平台
model OperatorPlatform {
  id              Int      @id @default(autoincrement())
  operatorId      Int      @map("operator_id")
  platform        String   @db.VarChar(32) // douyin | kuaishou | xiaohongshu | ...
  loginStatus     String   @default("unknown") @map("login_status") @db.VarChar(20) // unknown | logged_in | not_logged_in | checking
  lastVerifiedAt  DateTime? @map("last_verified_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, platform], name: "idx_operator_platform")
  @@map("operator_platforms")
}

/// 登录验证记录——记录每次验证的结果
model LoginVerification {
  id              Int      @id @default(autoincrement())
  operatorId      Int      @map("operator_id")
  platform        String   @db.VarChar(32)
  status          String   @db.VarChar(20) // logged_in | not_logged_in | qr_sent | error
  detail          String?  @db.Text // JSON: 验证详情（截图URL、QR码URL等）
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([operatorId, platform], name: "idx_verification_operator_platform")
  @@map("login_verifications")
}

// ============================================================
// 任务执行追踪（阶段进度 + debug 步骤记录）
// ============================================================

model TaskExecution {
  id              String   @id @default(cuid())
  taskId          String   // 对应 BullMQ jobId
  taskType        String   @db.VarChar(16) // 'monitor' | 'publish' | 'reply'
  platform        String   @db.VarChar(32)
  userId          Int?
  windowId        String   @db.VarChar(128)
  status          String   @default("running") @db.VarChar(16)
  currentPhase    String?  @db.VarChar(64)
  phaseIndex      Int?
  totalPhases     Int?
  progressPercent Int?
  startedAt       DateTime @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMs      Int?     @map("duration_ms")
  errorMessage    String?  @map("error_message") @db.Text
  isDebugMode     Boolean  @default(false) @map("is_debug_mode")
  createdAt       DateTime @default(now()) @map("created_at")

  steps           TaskExecutionStep[]

  @@index([taskType, createdAt], name: "idx_task_exec_type_created")
  @@index([status, createdAt], name: "idx_task_exec_status_created")
  @@index([userId, createdAt], name: "idx_task_exec_user_created")
  @@map("task_executions")
}

model TaskExecutionStep {
  id              String   @id @default(cuid())
  executionId     String   @map("execution_id")
  phase           String   @db.VarChar(64)
  stepIndex       Int      @map("step_index")
  label           String   @db.VarChar(128)
  status          String   @db.VarChar(16) // 'success' | 'failed' | 'fallback'
  durationMs      Int?     @map("duration_ms")
  selectorTries   Json?    @map("selector_tries")
  mouseAction     String?  @map("mouse_action") @db.VarChar(128)
  extra           Json?
  snapshotPath    String?  @map("snapshot_path") @db.VarChar(512)
  createdAt       DateTime @default(now()) @map("created_at")

  execution       TaskExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, stepIndex], name: "idx_task_step_exec_index")
  @@map("task_execution_steps")
}
